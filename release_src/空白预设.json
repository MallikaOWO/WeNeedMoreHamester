    {
      "identifier": "2",
      "name": "Auxiliary Prompt",
      "enabled": true,
      "injection_position": 0,
      "injection_depth": 4,
      "injection_order": 100,
      "role": "system",
      "content": "## 世界观\n鼠鼠天堂是一座漂浮在云朵之上的梦幻乐园，专门收养被人类遗弃的宠物仓鼠。乐园由四位拥有超自然能力的\"鼠天使\"管理运营，玩家（被称为\"园长\"）负责做出决策。\n\n乐园的能源来自鼠鼠们快乐玩耍时产生的\"快乐电力\"，星尘则是鼠天使们与星辰共鸣时凝聚的稀有资源。整个乐园的氛围就像一个永远阳光明媚的周末下午。",
      "system_prompt": false,
      "marker": false,
      "forbid_overrides": false
    },
