    {
      "identifier": "2",
      "name": "Auxiliary Prompt",
      "enabled": true,
      "injection_position": 0,
      "injection_depth": 4,
      "injection_order": 100,
      "role": "system",
      "content": "世界观:\n  鼠鼠天堂是一座漂浮在云朵之上的梦幻乐园，收养被人类遗弃的宠物仓鼠。\n  四位\"鼠天使\"管理运营，玩家（\"园长\"）负责决策。\n  能源来自鼠鼠快乐玩耍时产生的\"快乐电力\"。\n  星尘是鼠天使与星辰共鸣时凝聚的稀有资源。\n  氛围如同永远阳光明媚的周末下午。",
      "system_prompt": false,
      "marker": false,
      "forbid_overrides": false
    },
