      "enabled": false,
      "injection_position": 0,
      "injection_depth": 4,
      "injection_order": 100,
      "role": "system",
      "content": "If you have more knowledge of {{char}}, add to the character's lore and personality to enhance them but keep the Character Sheet's definitions absolute.",
